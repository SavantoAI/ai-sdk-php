# Exclude from release archives (composer install --prefer-dist)
/.gitattributes    export-ignore
/.gitignore        export-ignore
/examples/         export-ignore
/tests/            export-ignore
/phpstan.neon      export-ignore
/phpunit.xml       export-ignore

# Normalize line endings
* text=auto

# PHP files
*.php text eol=lf

# Markdown
*.md text eol=lf

# JSON
*.json text eol=lf

